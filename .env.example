# API Keys (Required)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./soar_lite.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/soar_lite

# Logging
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
